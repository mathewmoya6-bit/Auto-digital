# ─── LOGGING ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=auto-d.log
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ─── PERFORMANCE TUNING ──────────────────────────────────────────
WORKERS=4
THREADS=2
TIMEOUT=120
KEEPALIVE=5
MAX_REQUESTS=1000
MAX_REQUESTS_JITTER=100

# ─── BACKUP ──────────────────────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=auto-d-backups
BACKUP_S3_REGION=us-east-1

# ─── MAINTENANCE MODE ────────────────────────────────────────────
