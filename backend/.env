MAINTENANCE_MESSAGE=Auto-D Kenya is undergoing scheduled maintenance. We'll be back soon!

# ─── DEBUGGING ────────────────────────────────────────────────────
DEBUG=false
PROPAGATE_EXCEPTIONS=false
PRESERVE_CONTEXT_ON_EXCEPTION=false

# ─── API DOCUMENTATION ───────────────────────────────────────────
SWAGGER_ENABLED=false
SWAGGER_URL=/api/docs
REDOC_URL=/api/redoc

# ─── PERFORMANCE TUNING ──────────────────────────────────────────
WORKERS=4
THREADS=2
TIMEOUT=120
KEEPALIVE=5

# ─── BACKUP ──────────────────────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30
