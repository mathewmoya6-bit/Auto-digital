# ─── Flask Configuration ──────────────────────────────────────
FLASK_APP=app.py
FLASK_ENV=production
PORT=10000
FLASK_SECRET_KEY=your-super-secret-key-change-in-production
ALLOWED_ORIGINS=https://auto-d.meipressgroup.com,http://localhost:3000

# ─── M-Pesa Configuration ─────────────────────────────────────
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_PASSKEY=your_passkey
MPESA_SHORTCODE=174379
MPESA_ENVIRONMENT=sandbox  # or 'production' for live
MPESA_CALLBACK_URL=https://your-backend-url.onrender.com/api/mpesa/callback

# ─── Optional: Database ──────────────────────────────────────
# DATABASE_URL=postgresql://user:pass@localhost:5432/autod
# MONGODB_URI=mongodb://localhost:27017/autod

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Optional: Redis for caching ────────────────────────────
# REDIS_URL=redis://localhost:6379/0
